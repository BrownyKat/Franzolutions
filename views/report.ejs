<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MDRRMO — Report Emergency</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --amber:        #F59E0B;
      --amber-dark:   #D97706;
      --amber-deep:   #B45309;
      --amber-light:  #FFFBEB;
      --amber-border: #FCD34D;
      --orange:       #EA580C;
      --orange-light: #FFF7ED;
      --orange-border:#FDBA74;
      --red:          #DC2626;
      --red-light:    #FEF2F2;
      --red-border:   #FECACA;
      --green:        #059669;
      --green-light:  #ECFDF5;
      --green-border: #A7F3D0;
      --blue:         #1D4ED8;
      --bg:           #FAF8F4;
      --surface:      #FFFFFF;
      --border:       #E8E2D5;
      --border-mid:   #D5CBBA;
      --text:         #18120A;
      --text2:        #433720;
      --muted:        #7A6A50;
      --muted2:       #A89880;
      --shadow-sm: 0 1px 3px rgba(0,0,0,.07),0 1px 2px rgba(0,0,0,.04);
      --shadow-md: 0 4px 14px rgba(0,0,0,.08),0 2px 6px rgba(0,0,0,.04);
      --shadow-lg: 0 12px 36px rgba(0,0,0,.10),0 4px 14px rgba(0,0,0,.05);
      --shadow-xl: 0 24px 56px rgba(0,0,0,.12),0 8px 20px rgba(0,0,0,.06);
      --r-sm:8px; --r-md:12px; --r-lg:16px; --r-xl:20px;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;}
    ::-webkit-scrollbar{width:5px;} ::-webkit-scrollbar-track{background:var(--bg);} ::-webkit-scrollbar-thumb{background:var(--border-mid);border-radius:99px;}

    /* ── HEADER ── */
    .header {
      position:sticky;top:0;z-index:200;
      height:64px;
      display:flex;align-items:center;justify-content:space-between;
      padding:0 1.75rem;
      background:rgba(255,255,255,.93);
      backdrop-filter:blur(20px) saturate(160%);
      border-bottom:1px solid var(--border);
      box-shadow:0 1px 2px rgba(0,0,0,.05);
    }
    .brand{display:flex;align-items:center;gap:11px;text-decoration:none;color:inherit;}
    .brand-shield{
      width:38px;height:38px;
      background:linear-gradient(145deg,var(--amber),var(--orange));
      border-radius:10px;
      display:flex;align-items:center;justify-content:center;
      box-shadow:0 4px 14px rgba(245,158,11,.38);
      flex-shrink:0;
    }
    .brand-shield svg{width:22px;height:22px;stroke:#fff;stroke-width:1.8;fill:none;stroke-linecap:round;stroke-linejoin:round;}
    .brand-name{font-weight:800;font-size:.97rem;letter-spacing:-.2px;line-height:1.15;color:var(--text);}
    .brand-name em{font-style:normal;color:var(--amber-dark);}
    .brand-sub{font-family:'JetBrains Mono',monospace;font-size:.55rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);}
    .header-right{display:flex;align-items:center;gap:.65rem;}
    .nav-btn{
      display:inline-flex;align-items:center;gap:5px;
      padding:.36rem .8rem;border:1px solid var(--border-mid);border-radius:99px;
      background:transparent;color:var(--muted);
      font-family:'Outfit',sans-serif;font-size:.77rem;font-weight:600;
      cursor:pointer;text-decoration:none;transition:all .18s;
    }
    .nav-btn:hover{border-color:var(--muted2);color:var(--text2);background:var(--surface);}
    .nav-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
    .online-pill{
      display:flex;align-items:center;gap:6px;
      padding:.28rem .75rem;background:var(--green-light);
      border:1px solid var(--green-border);border-radius:99px;
      font-family:'JetBrains Mono',monospace;font-size:.6rem;font-weight:700;
      letter-spacing:1px;text-transform:uppercase;color:var(--green);
    }
    .online-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:blink 2s ease-in-out infinite;}
    @keyframes blink{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.35;transform:scale(.7)}}

    /* ── PANIC STRIP ── */
    .panic-strip{
      background:linear-gradient(180deg,#FFF1F2 0%,#FFF7ED 100%);
      border-bottom:1px solid rgba(220,38,38,.12);
      padding:2.5rem 1.5rem 2.75rem;
      text-align:center;position:relative;overflow:hidden;
    }
    .panic-strip::before{
      content:'';position:absolute;top:50%;left:50%;
      transform:translate(-50%,-50%);
      width:420px;height:420px;border-radius:50%;
      background:radial-gradient(circle,rgba(220,38,38,.05) 0%,transparent 68%);
      pointer-events:none;
    }
    .panic-eyebrow{
      font-family:'JetBrains Mono',monospace;font-size:2rem;font-weight:700;
      letter-spacing:3px;text-transform:uppercase;color:var(--orange);
      margin-bottom:1.4rem;position:relative;
    }
    .panic-btn{
      width:168px;height:168px;border-radius:50%;
      background:linear-gradient(145deg,#EF4444,#DC2626,#B91C1C);
      border:none;cursor:pointer;
      margin:0 auto 1.6rem;
      display:flex;flex-direction:column;align-items:center;justify-content:center;gap:9px;
      box-shadow:0 0 0 12px rgba(220,38,38,.09),0 0 0 24px rgba(220,38,38,.05),0 10px 40px rgba(220,38,38,.38);
      transition:transform .15s,box-shadow .15s;
      animation:panicPulse 3s ease-in-out infinite;
      position:relative;
    }
    @keyframes panicPulse{
      0%,100%{box-shadow:0 0 0 12px rgba(220,38,38,.09),0 0 0 24px rgba(220,38,38,.05),0 10px 40px rgba(220,38,38,.38);}
      50%{box-shadow:0 0 0 18px rgba(220,38,38,.12),0 0 0 34px rgba(220,38,38,.06),0 14px 52px rgba(220,38,38,.46);}
    }
    .panic-btn:active{transform:scale(.93);animation:none;}
    .panic-btn svg{width:44px;height:44px;stroke:#fff;stroke-width:1.6;fill:none;stroke-linecap:round;stroke-linejoin:round;}
    .panic-btn-label{font-weight:900;font-size:.8rem;letter-spacing:4px;text-transform:uppercase;color:rgba(255,255,255,.95);}
    .panic-sublabel{font-size:.88rem;color:var(--text2);max-width:290px;margin:0 auto;line-height:1.65;position:relative;}
    .panic-sublabel strong{color:var(--text);}
    .panic-number-pill{
      display:inline-flex;align-items:center;gap:7px;
      background:var(--surface);border:1px solid var(--border-mid);
      border-radius:99px;padding:.35rem 1rem;
      font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--muted);
      margin-top:.85rem;cursor:pointer;transition:all .18s;
    }
    .panic-number-pill:hover{border-color:var(--red);color:var(--red);}
    .panic-number-pill svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
    .panic-number-pill strong{color:var(--green);}

    /* ── FORM ── */
    .form-wrap{max-width:740px;margin:0 auto;padding:2.75rem 1.5rem 5rem;position:relative;z-index:1;}

    .form-head{margin-bottom:2.5rem;animation:fadeUp .5s ease both;}
    @keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
    .form-eyebrow{
      display:inline-flex;align-items:center;gap:6px;
      font-family:'JetBrains Mono',monospace;font-size:.6rem;font-weight:700;
      letter-spacing:2px;text-transform:uppercase;color:var(--amber-dark);
      background:var(--amber-light);border:1px solid var(--amber-border);
      border-radius:99px;padding:.28rem .85rem;margin-bottom:.9rem;
    }
    .form-eyebrow svg{width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
    .form-head h1{font-weight:900;font-size:2.9rem;line-height:1.05;letter-spacing:-2px;}
    .form-head h1 em{font-style:normal;color:var(--amber-dark);position:relative;}
    .form-head h1 em::after{
      content:'';position:absolute;bottom:-3px;left:0;right:0;height:3px;
      background:linear-gradient(90deg,var(--amber),var(--orange));
      border-radius:2px;opacity:.55;
    }
    .form-head p{margin-top:1rem;color:var(--text2);font-size:.95rem;line-height:1.7;max-width:500px;}

    .alert-strip{
      display:flex;align-items:flex-start;gap:.85rem;
      background:var(--orange-light);border:1px solid var(--orange-border);
      border-radius:var(--r-lg);padding:1.05rem 1.25rem;
      margin-bottom:2.25rem;font-size:.87rem;line-height:1.65;
      animation:fadeUp .4s .08s ease both;
    }
    .alert-strip svg{width:18px;height:18px;stroke:var(--orange);fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;margin-top:1px;}
    .alert-strip strong{color:var(--orange);}
    .alert-strip span{color:var(--text2);}

    /* cards */
    .card{
      background:var(--surface);border:1.5px solid var(--border);
      border-radius:var(--r-xl);padding:2rem;
      margin-bottom:1.25rem;
      box-shadow:var(--shadow-sm);
      transition:box-shadow .22s,border-color .22s;
      position:relative;overflow:hidden;
      animation:fadeUp .5s ease both;
    }
    .card::before{
      content:'';position:absolute;top:0;left:0;right:0;height:3px;
      background:linear-gradient(90deg,var(--amber),var(--orange),transparent);
      opacity:0;transition:opacity .22s;border-radius:var(--r-xl) var(--r-xl) 0 0;
    }
    .card:hover{box-shadow:var(--shadow-md);border-color:var(--border-mid);}
    .card:hover::before{opacity:1;}
    .card:nth-child(1){animation-delay:.07s;}
    .card:nth-child(2){animation-delay:.14s;}
    .card:nth-child(3){animation-delay:.21s;}
    .card:nth-child(4){animation-delay:.28s;}
    .card:nth-child(5){animation-delay:.35s;}

    .card-head{display:flex;align-items:flex-start;gap:14px;margin-bottom:1.6rem;}
    .card-icon{
      width:46px;height:46px;border-radius:11px;flex-shrink:0;
      background:var(--amber-light);border:1.5px solid var(--amber-border);
      display:flex;align-items:center;justify-content:center;
    }
    .card-icon svg{width:22px;height:22px;stroke:var(--amber-deep);fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;}
    .card-step{font-family:'JetBrains Mono',monospace;font-size:.58rem;font-weight:700;color:var(--amber-dark);letter-spacing:2px;text-transform:uppercase;margin-bottom:3px;}
    .card-title{font-weight:800;font-size:1.03rem;color:var(--text);letter-spacing:-.2px;}
    .card-sub{font-size:.77rem;color:var(--muted);margin-top:2px;}

    .row2{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
    @media(max-width:520px){.row2{grid-template-columns:1fr;}}
    .field{margin-bottom:1rem;}
    .field:last-child{margin-bottom:0;}
    .field label{display:block;font-size:.75rem;font-weight:700;color:var(--text2);margin-bottom:.45rem;text-transform:uppercase;letter-spacing:.5px;}
    .input-wrap{position:relative;}
    .input-wrap svg.field-icon{
      position:absolute;left:11px;top:50%;transform:translateY(-50%);
      width:15px;height:15px;stroke:var(--muted2);fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;
      pointer-events:none;
    }
    .input-wrap.has-icon input,
    .input-wrap.has-icon select{padding-left:2.35rem;}
    input,select,textarea{
      width:100%;background:var(--bg);border:1.5px solid var(--border);
      color:var(--text);padding:.78rem 1rem;border-radius:var(--r-md);
      font-family:'Outfit',sans-serif;font-size:.92rem;font-weight:500;
      transition:border-color .18s,box-shadow .18s,background .18s;
      outline:none;appearance:none;
    }
    input:focus,select:focus,textarea:focus{
      border-color:var(--amber);background:var(--surface);
      box-shadow:0 0 0 3.5px rgba(245,158,11,.13);
    }
    input::placeholder,textarea::placeholder{color:var(--muted2);font-weight:400;}
    textarea{resize:vertical;min-height:115px;}
    select option{background:#fff;}

    /* emergency type grid */
    .etype-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.85rem;}
    @media(max-width:440px){.etype-grid{grid-template-columns:repeat(2,1fr);}}
    .etype-btn{
      display:flex;flex-direction:column;align-items:center;gap:9px;
      padding:1.3rem .6rem 1.05rem;
      border:1.5px solid var(--border);border-radius:13px;
      background:var(--bg);color:var(--muted);
      cursor:pointer;font-family:'Outfit',sans-serif;font-weight:700;font-size:.82rem;
      transition:all .2s;
    }
    .etype-icon{
      width:42px;height:42px;border-radius:11px;
      background:var(--surface);border:1.5px solid var(--border);
      display:flex;align-items:center;justify-content:center;
      transition:all .2s;
    }
    .etype-icon svg{width:20px;height:20px;stroke:var(--muted);fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;transition:stroke .2s;}
    .etype-btn:hover,.etype-btn.sel{
      border-color:var(--amber);background:var(--amber-light);
      color:var(--amber-deep);transform:translateY(-3px);
      box-shadow:0 6px 20px rgba(245,158,11,.18);
    }
    .etype-btn:hover .etype-icon,.etype-btn.sel .etype-icon{background:var(--amber-light);border-color:var(--amber-border);}
    .etype-btn:hover .etype-icon svg,.etype-btn.sel .etype-icon svg{stroke:var(--amber-deep);}

    /* severity */
    .sev-row{display:grid;grid-template-columns:repeat(3,1fr);gap:.85rem;}
    .sev-btn{
      display:flex;align-items:center;justify-content:center;gap:7px;
      padding:.9rem;border:1.5px solid var(--border);border-radius:11px;
      background:var(--bg);color:var(--muted);
      cursor:pointer;font-family:'Outfit',sans-serif;font-weight:700;font-size:.88rem;
      transition:all .2s;
    }
    .sev-btn svg{width:17px;height:17px;fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;transition:stroke .2s;}
    .sev-btn.low:hover,.sev-btn.low.sel   {background:var(--green-light);border-color:var(--green);color:var(--green);transform:translateY(-2px);box-shadow:0 4px 14px rgba(5,150,105,.14);}
    .sev-btn.low:hover svg,.sev-btn.low.sel svg{stroke:var(--green);}
    .sev-btn.med:hover,.sev-btn.med.sel   {background:var(--amber-light);border-color:var(--amber);color:var(--amber-dark);transform:translateY(-2px);box-shadow:0 4px 14px rgba(245,158,11,.14);}
    .sev-btn.med:hover svg,.sev-btn.med.sel svg{stroke:var(--amber-dark);}
    .sev-btn.high:hover,.sev-btn.high.sel {background:var(--red-light);border-color:var(--red);color:var(--red);transform:translateY(-2px);box-shadow:0 4px 14px rgba(220,38,38,.14);}
    .sev-btn.high:hover svg,.sev-btn.high.sel svg{stroke:var(--red);}

    /* gps btn */
    .gps-btn{
      width:100%;display:flex;align-items:center;justify-content:center;gap:8px;
      padding:.88rem;border:1.5px dashed var(--border-mid);border-radius:var(--r-md);
      background:var(--bg);color:var(--muted);
      font-family:'Outfit',sans-serif;font-size:.88rem;font-weight:600;
      cursor:pointer;transition:all .2s;margin-bottom:1rem;
    }
    .gps-btn svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;}
    .gps-btn:hover{border-style:solid;border-color:var(--amber);color:var(--amber-dark);background:var(--amber-light);}
    .gps-btn.got{border-style:solid;border-color:var(--green);color:var(--green);background:var(--green-light);}
    .gps-map-wrap{
      display:none;
      margin:-.2rem 0 1rem;
      border:1.5px solid var(--border);
      border-radius:12px;
      overflow:hidden;
      background:var(--surface);
    }
    .gps-map-head{
      display:flex;align-items:center;justify-content:space-between;gap:.65rem;
      padding:.55rem .75rem;
      border-bottom:1px solid var(--border);
      background:var(--surface2);
      font-family:'JetBrains Mono',monospace;
      font-size:.62rem;font-weight:700;letter-spacing:.7px;color:var(--muted);
      text-transform:uppercase;
    }
    .gps-map-head a{
      color:var(--amber-dark);
      text-decoration:none;
      font-weight:700;
    }
    .gps-map-head a:hover{text-decoration:underline;}
    .gps-map-frame{
      width:100%;
      height:210px;
      border:0;
      display:block;
      background:#F3F4F6;
    }

    /* upload */
    .upload-area{
      position:relative;border:2px dashed var(--border-mid);border-radius:13px;
      padding:2.25rem 2rem;text-align:center;cursor:pointer;
      background:var(--bg);color:var(--muted);font-size:.88rem;
      transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:.5rem;
    }
    .upload-area svg{width:34px;height:34px;stroke:var(--muted2);fill:none;stroke-width:1.5;margin-bottom:.2rem;transition:stroke .2s;}
    .upload-area:hover{border-color:var(--amber);color:var(--amber-dark);background:var(--amber-light);}
    .upload-area:hover svg{stroke:var(--amber-dark);}
    .upload-area input{position:absolute;inset:0;opacity:0;cursor:pointer;}
    .upload-label{font-weight:600;}
    .upload-hint{font-size:.74rem;color:var(--muted2);}

    /* submit */
    .submit-btn{
      width:100%;display:flex;align-items:center;justify-content:center;gap:9px;
      padding:1.1rem;margin-top:.65rem;
      background:linear-gradient(135deg,var(--amber),var(--orange));
      color:#fff;border:none;border-radius:var(--r-lg);
      font-family:'Outfit',sans-serif;font-weight:800;font-size:.98rem;
      cursor:pointer;transition:all .22s;
      box-shadow:0 6px 24px rgba(234,88,12,.34);position:relative;overflow:hidden;
    }
    .submit-btn svg{width:19px;height:19px;stroke:#fff;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
    .submit-btn:hover{transform:translateY(-2px);box-shadow:0 12px 34px rgba(234,88,12,.44);}
    .submit-btn:active{transform:translateY(0);}
    .submit-btn::after{
      content:'';position:absolute;inset:0;
      background:linear-gradient(90deg,transparent,rgba(255,255,255,.18),transparent);
      transform:translateX(-100%);transition:transform .55s;
    }
    .submit-btn:hover::after{transform:translateX(100%);}

    /* ── MODALS / OVERLAYS ── */
    .overlay{
      display:none;position:fixed;inset:0;
      background:rgba(250,248,244,.96);backdrop-filter:blur(14px);
      z-index:500;align-items:center;justify-content:center;
      flex-direction:column;text-align:center;padding:2rem;
    }
    .overlay.show{display:flex;animation:fadeIn .25s ease;}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}

    /* success overlay */
    .success-ring{
      width:90px;height:90px;border-radius:50%;
      background:var(--green-light);border:2px solid var(--green-border);
      display:flex;align-items:center;justify-content:center;
      margin-bottom:1.75rem;
      animation:scaleIn .4s .15s ease both;
      box-shadow:0 8px 36px rgba(5,150,105,.2);
    }
    @keyframes scaleIn{from{transform:scale(.5);opacity:0}to{transform:scale(1);opacity:1}}
    .success-ring svg{width:40px;height:40px;stroke:var(--green);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
    .overlay h2{font-weight:900;font-size:2.1rem;letter-spacing:-1px;margin-bottom:.65rem;}
    .overlay p{color:var(--text2);max-width:370px;line-height:1.7;font-size:.93rem;}
    .rpt-id{
      margin-top:1.6rem;padding:1rem 2.5rem;
      background:var(--amber-light);border:1.5px solid var(--amber-border);border-radius:13px;
      font-family:'JetBrains Mono',monospace;font-size:1.55rem;font-weight:700;
      letter-spacing:4px;color:var(--amber-dark);
    }
    .ghost-btn{
      margin-top:1.75rem;padding:.75rem 2rem;
      background:var(--surface);border:1.5px solid var(--border-mid);
      border-radius:var(--r-md);color:var(--text2);
      font-family:'Outfit',sans-serif;font-weight:700;font-size:.88rem;cursor:pointer;
      transition:all .18s;
    }
    .ghost-btn:hover{border-color:var(--amber);color:var(--amber-dark);background:var(--amber-light);}

    /* panic setup modal */
    .modal-box{
      background:var(--surface);border:1.5px solid var(--border-mid);
      border-top:3px solid var(--red);border-radius:var(--r-xl);
      padding:2.5rem;max-width:420px;width:100%;text-align:center;
      box-shadow:var(--shadow-xl);
    }
    .modal-icon-wrap{
      width:50px;height:50px;border-radius:12px;
      background:var(--red-light);border:1.5px solid var(--red-border);
      display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem;
    }
    .modal-icon-wrap svg{width:24px;height:24px;stroke:var(--red);fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;}
    .modal-box h3{font-weight:900;font-size:1.65rem;letter-spacing:-.5px;margin-bottom:.55rem;}
    .modal-box p{color:var(--text2);font-size:.86rem;line-height:1.7;margin-bottom:1.6rem;}
    .modal-box input{
      width:100%;background:var(--bg);border:1.5px solid var(--border-mid);
      color:var(--text);padding:.9rem 1rem;border-radius:var(--r-md);
      font-family:'JetBrains Mono',monospace;font-size:1.05rem;
      outline:none;text-align:center;letter-spacing:3px;margin-bottom:1rem;transition:all .18s;
    }
    .modal-box input:focus{border-color:var(--red);box-shadow:0 0 0 3.5px rgba(220,38,38,.1);background:var(--surface);}
    .modal-save{
      width:100%;padding:.95rem;
      background:linear-gradient(135deg,#EF4444,#DC2626);
      color:#fff;border:none;border-radius:var(--r-md);
      font-family:'Outfit',sans-serif;font-weight:800;font-size:.97rem;cursor:pointer;
      box-shadow:0 4px 20px rgba(220,38,38,.3);transition:all .2s;
    }
    .modal-save:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(220,38,38,.4);}
    .modal-cancel{display:block;width:100%;padding:.55rem;margin-top:.6rem;background:none;border:none;color:var(--muted);cursor:pointer;font-family:'Outfit',sans-serif;font-size:.85rem;font-weight:600;}

    /* panic sending overlay */
    .sending-ring{
      width:130px;height:130px;border-radius:50%;
      border:3px solid rgba(220,38,38,.15);border-top-color:var(--red);
      animation:spin .9s linear infinite;margin-bottom:2rem;
      display:flex;align-items:center;justify-content:center;
    }
    @keyframes spin{to{transform:rotate(360deg)}}
    .sending-ring svg{width:50px;height:50px;stroke:var(--red);fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round;}
    .overlay h2.red{color:var(--red);}
    .overlay h2.green-h{color:var(--green);}
    .confirmed{display:none;flex-direction:column;align-items:center;}
    .confirmed.show{display:flex;}
    .confirm-ring{
      width:78px;height:78px;border-radius:50%;
      background:var(--green-light);border:2px solid var(--green-border);
      display:flex;align-items:center;justify-content:center;
      margin-bottom:1.4rem;box-shadow:0 8px 28px rgba(5,150,105,.2);
    }
    .confirm-ring svg{width:34px;height:34px;stroke:var(--green);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
    .sos-id-box{
      margin-top:1.4rem;padding:1rem 2.25rem;
      background:var(--red-light);border:1.5px solid var(--red-border);border-radius:12px;
      font-family:'JetBrains Mono',monospace;font-size:1.7rem;font-weight:700;
      letter-spacing:4px;color:var(--red);
    }
    .sos-id-label{font-family:'JetBrains Mono',monospace;font-size:.58rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:5px;}
    .gps-note{margin-top:.85rem;font-size:.74rem;color:var(--muted);font-family:'JetBrains Mono',monospace;}

    /* toast */
    .toast{
      position:fixed;bottom:1.75rem;right:1.75rem;z-index:999;
      display:flex;align-items:flex-start;gap:10px;
      padding:.95rem 1.1rem;background:var(--surface);
      border:1px solid var(--border-mid);border-left:3px solid var(--green);
      border-radius:var(--r-md);box-shadow:var(--shadow-xl);max-width:300px;
      transform:translateX(calc(100% + 2rem));
      transition:transform .35s cubic-bezier(.34,1.56,.64,1);
    }
    .toast.show{transform:translateX(0);}
    .toast svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;margin-top:1px;}
    .toast strong{display:block;font-weight:700;font-size:.83rem;color:var(--text);margin-bottom:1px;}
    .toast span{font-size:.76rem;color:var(--text2);}

    @media(max-width:768px){
      .form-wrap{padding:2rem 1rem 3.5rem;}
      .form-head h1{font-size:2.2rem;}
      .card{padding:1.5rem;}
    }
  </style>
</head>
<body>

<!-- HEADER -->
<header class="header">
  <a href="/" class="brand">
    <div class="brand-shield">
      <!-- Heroicon: shield-check -->
      <svg viewBox="0 0 24 24"><path d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
    </div>
    <div>
      <div class="brand-name">FRANZ<em>OLU</em>TIONS</div>
      <div class="brand-sub">Emergency Reporting</div>
    </div>
  </a>
  <div class="header-right">
    <div class="online-pill"><div class="online-dot"></div>Online</div>
  </div>
</header>

<!-- PANIC STRIP -->
<div class="panic-strip">
  <div class="panic-eyebrow"><span>Urgent Emergency</span></div>
  <button class="panic-btn" id="panicBtn" onclick="triggerPanic()">
    <!-- Heroicon: exclamation-triangle -->
    <svg viewBox="0 0 24 24"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
    <div class="panic-btn-label">PANIC SOS</div>
  </button>
  <div class="panic-sublabel" id="panicSublabel">
    <strong>Tap to send instant SOS.</strong><br>Sends your exact location immediately - no forms needed.
  </div>
  <div class="panic-number-pill" id="panicPill" onclick="openPanicSetup()" style="display:none;">
    <!-- Heroicon: phone -->
    <svg viewBox="0 0 24 24"><path d="M2.25 6.338c0 7.5 6.089 13.587 13.589 13.587l.682-.002a1.124 1.124 0 0 0 1.12-1.065l.254-3.223a1.125 1.125 0 0 0-.89-1.207l-2.98-.67a1.125 1.125 0 0 0-1.264.597l-.75 1.5a11.775 11.775 0 0 1-4.955-4.955l1.5-.75a1.125 1.125 0 0 0 .597-1.264l-.67-2.98a1.125 1.125 0 0 0-1.207-.89l-3.223.254a1.124 1.124 0 0 0-1.065 1.12L2.25 6.338Z"/></svg>
    Sending as: <strong id="savedNum"></strong> &nbsp;·&nbsp; tap to change
  </div>
</div>

<!-- FORM -->
<div class="form-wrap">
  <div class="form-head">
    <div class="form-eyebrow">
      <!-- Heroicon: document-text -->
      <svg viewBox="0 0 24 24"><path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
      MDRRMO Emergency Report System
    </div>
    <h1>Report an <em>Emergency</em></h1>
    <p>Your report will be received immediately by MDRRMO dispatchers. Provide as much detail as possible for a faster response.</p>
  </div>

  <div class="alert-strip">
    <!-- Heroicon: exclamation-triangle -->
    <svg viewBox="0 0 24 24"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
    <span><strong>For life-threatening emergencies, call 911 immediately.</strong><br>This form is for reporting incidents and requesting assistance from your local MDRRMO.</span>
  </div>

  <!-- STEP 01 -->
  <div class="card">
    <div class="card-head">
      <div class="card-icon">
        <!-- Heroicon: user -->
        <svg viewBox="0 0 24 24"><path d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
      </div>
      <div>
        <div class="card-step">Step 01</div>
        <div class="card-title">Your Information</div>
        <div class="card-sub">Who is making this report?</div>
      </div>
    </div>
    <div class="row2">
      <div class="field">
        <label>Full Name *</label>
        <div class="input-wrap has-icon">
          <svg class="field-icon" viewBox="0 0 24 24"><path d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
          <input type="text" id="iName" placeholder="Juan dela Cruz">
        </div>
      </div>
      <div class="field">
        <label>Contact Number *</label>
        <div class="input-wrap has-icon">
          <svg class="field-icon" viewBox="0 0 24 24"><path d="M2.25 6.338c0 7.5 6.089 13.587 13.589 13.587l.682-.002a1.124 1.124 0 0 0 1.12-1.065l.254-3.223a1.125 1.125 0 0 0-.89-1.207l-2.98-.67a1.125 1.125 0 0 0-1.264.597l-.75 1.5a11.775 11.775 0 0 1-4.955-4.955l1.5-.75a1.125 1.125 0 0 0 .597-1.264l-.67-2.98a1.125 1.125 0 0 0-1.207-.89l-3.223.254a1.124 1.124 0 0 0-1.065 1.12L2.25 6.338Z"/></svg>
          <input type="tel" id="iContact" placeholder="09XX XXX XXXX">
        </div>
      </div>
    </div>
  </div>

  <!-- STEP 02 -->
  <div class="card">
    <div class="card-head">
      <div class="card-icon">
        <!-- Heroicon: exclamation-circle -->
        <svg viewBox="0 0 24 24"><path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
      </div>
      <div>
        <div class="card-step">Step 02</div>
        <div class="card-title">Type of Emergency</div>
        <div class="card-sub">Select the category that best describes the incident</div>
      </div>
    </div>
    <div class="etype-grid">
      <div class="etype-btn" onclick="selType(this,'Fire')">
        <div class="etype-icon">
          <!-- Heroicon: fire -->
          <svg viewBox="0 0 24 24"><path d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z"/><path d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z"/></svg>
        </div>Fire
      </div>
      <div class="etype-btn" onclick="selType(this,'Flood')">
        <div class="etype-icon">
          <!-- Heroicon: cloud -->
          <svg viewBox="0 0 24 24"><path d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z"/></svg>
        </div>Flood
      </div>
      <div class="etype-btn" onclick="selType(this,'Medical')">
        <div class="etype-icon">
          <!-- Heroicon: heart -->
          <svg viewBox="0 0 24 24"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z"/></svg>
        </div>Medical
      </div>
      <div class="etype-btn" onclick="selType(this,'Accident')">
        <div class="etype-icon">
          <!-- Heroicon: truck -->
          <svg viewBox="0 0 24 24"><path d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M8.25 18.75V3.375c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v.75"/></svg>
        </div>Accident
      </div>
      <div class="etype-btn" onclick="selType(this,'Landslide')">
        <div class="etype-icon">
          <!-- Heroicon: chart-bar -->
          <svg viewBox="0 0 24 24"><path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>
        </div>Landslide
      </div>
      <div class="etype-btn" onclick="selType(this,'Other')">
        <div class="etype-icon">
          <!-- Heroicon: ellipsis-horizontal-circle -->
          <svg viewBox="0 0 24 24"><path d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        </div>Other
      </div>
    </div>
    <input type="hidden" id="iType">
  </div>

  <!-- STEP 03 -->
  <div class="card">
    <div class="card-head">
      <div class="card-icon">
        <!-- Heroicon: bolt -->
        <svg viewBox="0 0 24 24"><path d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>
      </div>
      <div>
        <div class="card-step">Step 03</div>
        <div class="card-title">Severity Level</div>
        <div class="card-sub">How serious is the situation right now?</div>
      </div>
    </div>
    <div class="sev-row">
      <button class="sev-btn low" onclick="selSev(this,'Low')">
        <!-- Heroicon: check-circle -->
        <svg viewBox="0 0 24 24"><path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Low
      </button>
      <button class="sev-btn med" onclick="selSev(this,'Medium')">
        <!-- Heroicon: exclamation-circle -->
        <svg viewBox="0 0 24 24"><path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>Medium
      </button>
      <button class="sev-btn high" onclick="selSev(this,'High')">
        <!-- Heroicon: exclamation-triangle -->
        <svg viewBox="0 0 24 24"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>High
      </button>
    </div>
    <input type="hidden" id="iSev">
  </div>

  <!-- STEP 04 -->
  <div class="card">
    <div class="card-head">
      <div class="card-icon">
        <!-- Heroicon: map-pin -->
        <svg viewBox="0 0 24 24"><path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
      </div>
      <div>
        <div class="card-step">Step 04</div>
        <div class="card-title">Location</div>
        <div class="card-sub">Where is the emergency happening?</div>
      </div>
    </div>
    <button class="gps-btn" id="gpsBtn" onclick="detectGPS()">
      <!-- Heroicon: signal -->
      <svg viewBox="0 0 24 24"><path d="M9.348 14.651a3.75 3.75 0 0 1 0-5.303m5.304-.001a3.75 3.75 0 0 1 0 5.304m-7.425 2.122a6.75 6.75 0 0 1 0-9.546m9.546 0a6.75 6.75 0 0 1 0 9.546M5.106 18.894c-3.808-3.808-3.808-9.98 0-13.789m13.788 0c3.808 3.808 3.808 9.981 0 13.79M12 12h.008v.007H12V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>
      Auto-detect My Location (GPS)
    </button>
    <div class="gps-map-wrap" id="gpsMapWrap">
      <div class="gps-map-head">
        <span id="gpsMapLabel">Detected location</span>
        <a id="gpsMapLink" href="#" target="_blank" rel="noopener noreferrer">Open map</a>
      </div>
      <iframe class="gps-map-frame" id="gpsMapFrame" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
    <input type="hidden" id="iGPS">
    <input type="hidden" id="iGPSAt">
    <input type="hidden" id="iGPSAcc">
    <div class="row2">
      <div class="field">
        <label>Barangay *</label>
        <div class="input-wrap has-icon">
          <svg class="field-icon" viewBox="0 0 24 24"><path d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z"/></svg>
          <input type="text" id="iBarangay" placeholder="e.g. Barangay Rizal">
        </div>
      </div>
      <div class="field">
        <label>Nearest Landmark *</label>
        <div class="input-wrap has-icon">
          <svg class="field-icon" viewBox="0 0 24 24"><path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
          <input type="text" id="iLandmark" placeholder="e.g. Near Municipal Hall">
        </div>
      </div>
    </div>
    <div class="field">
      <label>Street / Additional Details</label>
      <div class="input-wrap has-icon">
        <svg class="field-icon" viewBox="0 0 24 24"><path d="M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5"/></svg>
        <input type="text" id="iStreet" placeholder="Street name or additional details">
      </div>
    </div>
  </div>

  <!-- STEP 05 -->
  <div class="card">
    <div class="card-head">
      <div class="card-icon">
        <!-- Heroicon: pencil-square -->
        <svg viewBox="0 0 24 24"><path d="M16.862 4.487 18.55 2.8a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/></svg>
      </div>
      <div>
        <div class="card-step">Step 05</div>
        <div class="card-title">Incident Details</div>
        <div class="card-sub">Describe the situation and attach a photo if possible</div>
      </div>
    </div>
    <div class="field">
      <label>Description *</label>
      <textarea id="iDesc" placeholder="Describe what is happening. Include: number of people affected, current situation, any danger present…"></textarea>
    </div>
    <div class="field">
      <label>Upload Photo (Optional)</label>
      <div class="upload-area" id="uploadArea">
        <input type="file" accept="image/*" onchange="handlePhoto(this)">
        <!-- Heroicon: camera -->
        <svg viewBox="0 0 24 24"><path d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z"/><path d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z"/></svg>
        <div class="upload-label">Click or drag to upload a photo</div>
        <div class="upload-hint">JPG, PNG — up to 10 MB</div>
      </div>
    </div>
  </div>

  <button class="submit-btn" onclick="submitReport()">
    <!-- Heroicon: paper-airplane -->
    <svg viewBox="0 0 24 24"><path d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"/></svg>
    Submit Emergency Report
  </button>
</div>

<!-- SUCCESS OVERLAY -->
<div class="overlay" id="successOverlay">
  <div class="success-ring">
    <svg viewBox="0 0 24 24"><path d="M4.5 12.75l6 6 9-13.5"/></svg>
  </div>
  <h2>Report Submitted</h2>
  <p>Your emergency report has been received by MDRRMO dispatchers. You will be contacted at your provided number for verification.</p>
  <div class="rpt-id" id="rptId">RPT-0000</div>
  <button class="ghost-btn" onclick="closeSuccess()">Submit Another Report</button>
</div>

<!-- PANIC SETUP MODAL -->
<div class="overlay" id="panicModal">
  <div class="modal-box">
    <div class="modal-icon-wrap">
      <!-- Heroicon: lock-closed -->
      <svg viewBox="0 0 24 24"><path d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
    </div>
    <h3>One-Time Setup</h3>
    <p>Enter your phone number <strong>once</strong>. The Panic Button will remember it so you never need to type again in an emergency.</p>
    <input type="tel" id="panicInput" placeholder="09XX XXX XXXX" maxlength="13">
    <button class="modal-save" onclick="savePanic()">Save &amp; Activate Panic Button</button>
    <button class="modal-cancel" onclick="closePanicModal()">Cancel</button>
  </div>
</div>

<!-- PANIC SENDING OVERLAY -->
<div class="overlay" id="sendingOverlay">
  <div id="sendingState">
    <div class="sending-ring">
      <svg viewBox="0 0 24 24"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
    </div>
    <h2 class="red">Sending SOS…</h2>
    <p style="color:var(--text2);margin-top:.5rem;font-size:.93rem;">Acquiring exact location and alerting dispatchers</p>
  </div>
  <div class="confirmed" id="confirmedState">
    <div class="confirm-ring">
      <svg viewBox="0 0 24 24"><path d="M4.5 12.75l6 6 9-13.5"/></svg>
    </div>
    <h2 class="green-h" style="font-size:2rem;letter-spacing:-1px;margin-bottom:.55rem;">SOS Sent!</h2>
    <p style="color:var(--text2);max-width:310px;line-height:1.7;font-size:.9rem;">
      Dispatchers have been alerted. <strong style="color:var(--text);">Stay on the line — they will call you back immediately.</strong>
    </p>
    <div style="margin-top:1.4rem;">
      <div class="sos-id-label">Your SOS ID</div>
      <div class="sos-id-box" id="sosId">SOS-0000</div>
    </div>
    <div class="gps-note" id="gpsNote"></div>
    <button class="ghost-btn" onclick="closeSending()" style="margin-top:1.5rem;">Close</button>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast">
  <svg viewBox="0 0 24 24"><path d="M11.25 11.25l.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"/></svg>
  <div><strong id="toastTitle"></strong><span id="toastMsg"></span></div>
</div>

<script>
  let selType_ = '', selSev_ = '', photoData = null;
  let panicNum = '';
  try { panicNum = localStorage.getItem('mdrrmo_panic') || ''; } catch(e) {}
  if (panicNum) initPanicUI();

  function initPanicUI() {
    document.getElementById('savedNum').textContent = panicNum;
    document.getElementById('panicPill').style.display = 'inline-flex';
    document.getElementById('panicSublabel').innerHTML = '<strong>One tap sends instant SOS.</strong><br>Your exact location will be sent to dispatchers immediately.';
  }

  function selType(el, t) {
    document.querySelectorAll('.etype-btn').forEach(b => b.classList.remove('sel'));
    el.classList.add('sel'); selType_ = t;
  }
  function selSev(el, s) {
    document.querySelectorAll('.sev-btn').forEach(b => b.classList.remove('sel'));
    el.classList.add('sel'); selSev_ = s;
  }

  function detectGPS() {
    const btn = document.getElementById('gpsBtn');
    btn.disabled = true;
    btn.innerHTML = `<svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;animation:spin .9s linear infinite"><path d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg> Detecting…`;
    if (!navigator.geolocation) { btn.textContent = 'GPS not available on this device'; btn.disabled = false; return; }
    navigator.geolocation.getCurrentPosition(
      pos => {
        const c = `${pos.coords.latitude.toFixed(5)}, ${pos.coords.longitude.toFixed(5)}`;
        document.getElementById('iGPS').value = c;
        document.getElementById('iGPSAt').value = String(Date.now());
        document.getElementById('iGPSAcc').value = String(Math.round(pos.coords.accuracy || 0));
        renderReporterMap(c, 'Detected location');
        void autoFillLocationFromCoords(pos.coords.latitude, pos.coords.longitude);
        btn.classList.add('got');
        btn.innerHTML = `<svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round"><path d="M4.5 12.75l6 6 9-13.5"/></svg> Detected: ${pos.coords.latitude.toFixed(4)}, ${pos.coords.longitude.toFixed(4)} (±${Math.round(pos.coords.accuracy || 0)}m)`;
        btn.disabled = false;
      },
      () => { btn.textContent = 'Could not detect location — fill in manually.'; btn.disabled = false; }
      , { enableHighAccuracy: true, timeout: 12000, maximumAge: 0 }
    );
  }

  function handlePhoto(input) {
    if (!input.files[0]) return;
    const r = new FileReader();
    r.onload = e => {
      photoData = e.target.result;
      document.getElementById('uploadArea').innerHTML = `<img src="${photoData}" style="max-height:120px;border-radius:9px;max-width:100%;"><p style="margin-top:8px;font-size:.82rem;color:var(--green);font-weight:700;">Photo attached</p>`;
    };
    r.readAsDataURL(input.files[0]);
  }

  async function submitReport() {
    const name = document.getElementById('iName').value.trim();
    const contact = document.getElementById('iContact').value.trim();
    const barangay = document.getElementById('iBarangay').value;
    const landmark = document.getElementById('iLandmark').value.trim();
    const description = document.getElementById('iDesc').value.trim();
    if (!name||!contact||!selType_||!selSev_||!barangay||!landmark||!description) {
      toast('Missing fields', 'Please complete all required fields and selections.','warn'); return;
    }

    // Always try to refresh GPS right before sending report for better accuracy.
    const liveGps = await tryGetLiveGps(12000);
    const gpsValue = liveGps || document.getElementById('iGPS').value;
    if (!parseGps(gpsValue)) {
      toast('Location required', 'Please enable Location/GPS and try again.','warn');
      return;
    }

    try {
      const res = await fetch('/api/report', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ name, contact, emergencyType: selType_, severity: selSev_, barangay, landmark, street: document.getElementById('iStreet').value.trim(), description, gps: gpsValue, photo: photoData })
      });
      const d = await res.json();
      if (d.success) { document.getElementById('rptId').textContent = d.id; document.getElementById('successOverlay').classList.add('show'); resetForm(); }
    } catch(e) { toast('Error', 'Could not submit. Please try again.','warn'); }
  }

  function resetForm() {
    ['iName','iContact','iLandmark','iStreet','iDesc','iGPS','iGPSAt','iGPSAcc'].forEach(id => document.getElementById(id).value='');
    document.getElementById('iBarangay').value='';
    document.querySelectorAll('.etype-btn').forEach(b=>b.classList.remove('sel'));
    document.querySelectorAll('.sev-btn').forEach(b=>b.classList.remove('sel'));
    selType_=''; selSev_=''; photoData=null;
    const g=document.getElementById('gpsBtn');
    g.classList.remove('got'); g.disabled=false;
    document.getElementById('gpsMapWrap').style.display='none';
    g.innerHTML=`<svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round"><path d="M9.348 14.651a3.75 3.75 0 0 1 0-5.303m5.304-.001a3.75 3.75 0 0 1 0 5.304m-7.425 2.122a6.75 6.75 0 0 1 0-9.546m9.546 0a6.75 6.75 0 0 1 0 9.546M5.106 18.894c-3.808-3.808-3.808-9.98 0-13.789m13.788 0c3.808 3.808 3.808 9.981 0 13.79M12 12h.008v.007H12V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg> Auto-detect My Location (GPS)`;
    document.getElementById('uploadArea').innerHTML=`<input type="file" accept="image/*" onchange="handlePhoto(this)"><svg viewBox="0 0 24 24" style="width:34px;height:34px;stroke:var(--muted2);fill:none;stroke-width:1.5;margin-bottom:.2rem;transition:stroke .2s"><path d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z"/><path d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z"/></svg><div class="upload-label">Click or drag to upload a photo</div><div class="upload-hint">JPG, PNG — up to 10 MB</div>`;
  }

  function closeSuccess() { document.getElementById('successOverlay').classList.remove('show'); }

  // panic
  function openPanicSetup() {
    document.getElementById('panicInput').value = panicNum;
    document.getElementById('panicModal').classList.add('show');
    setTimeout(()=>document.getElementById('panicInput').focus(),150);
  }
  function closePanicModal() { document.getElementById('panicModal').classList.remove('show'); }
  function savePanic() {
    const n = document.getElementById('panicInput').value.trim();
    if (!n || n.length < 10) { document.getElementById('panicInput').style.borderColor='var(--red)'; return; }
    panicNum = n;
    try { localStorage.setItem('mdrrmo_panic', n); } catch(e) {}
    closePanicModal(); initPanicUI();
    toast('Panic Button Ready', 'Number saved. One tap = instant SOS.');
  }
  function triggerPanic() {
    if (!panicNum) { openPanicSetup(); return; }
    document.getElementById('sendingState').style.display='block';
    document.getElementById('confirmedState').classList.remove('show');
    document.getElementById('sendingOverlay').classList.add('show');
    const send = async loc => {
      const payload = {
        contact: panicNum,
        gps: loc.gps || 'unavailable',
        barangay: loc.barangay || '',
        landmark: loc.landmark || '',
        street: loc.street || '',
      };
      try {
        const res = await fetch('/api/panic',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
        const d = await res.json();
        document.getElementById('sendingState').style.display='none';
        document.getElementById('sosId').textContent = d.id;
        document.getElementById('gpsNote').textContent = loc.locationText || 'Location unavailable - dispatcher will call you';
        document.getElementById('confirmedState').classList.add('show');
      } catch(e) { closeSending(); toast('Error','Could not send SOS.','warn'); }
    };

    const fallbackGps = document.getElementById('iGPS').value || '';
    const fallbackGpsAt = Number(document.getElementById('iGPSAt').value || 0);
    const fallbackGpsAcc = Number(document.getElementById('iGPSAcc').value || 99999);
    const FALLBACK_MAX_AGE_MS = 2 * 60 * 1000; // 2 minutes
    const FALLBACK_MAX_ACC_M = 200; // reject very coarse locations
    const sendWithFallback = async () => {
      const ageOk = fallbackGpsAt > 0 && (Date.now() - fallbackGpsAt) <= FALLBACK_MAX_AGE_MS;
      const accOk = Number.isFinite(fallbackGpsAcc) && fallbackGpsAcc <= FALLBACK_MAX_ACC_M;
      if (parseGps(fallbackGps) && ageOk && accOk) {
        renderReporterMap(fallbackGps, 'Panic SOS location');
        const loc = await buildPanicLocationPayload(fallbackGps);
        await send(loc);
      } else {
        await send({ gps: 'unavailable', barangay: '', landmark: '', street: '', locationText: 'Location unavailable - dispatcher will call you' });
      }
    };

    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        async p => {
          const gps = `${p.coords.latitude.toFixed(5)}, ${p.coords.longitude.toFixed(5)}`;
          document.getElementById('iGPS').value = gps;
          document.getElementById('iGPSAt').value = String(Date.now());
          document.getElementById('iGPSAcc').value = String(Math.round(p.coords.accuracy || 0));
          renderReporterMap(gps, 'Panic SOS location');
          const loc = await buildPanicLocationPayload(gps);
          await send(loc);
        },
        () => { void sendWithFallback(); },
        { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
      );
    } else { void sendWithFallback(); }
  }
  function closeSending() { document.getElementById('sendingOverlay').classList.remove('show'); }

  function toast(title, msg, type='info') {
    const t=document.getElementById('toast');
    document.getElementById('toastTitle').textContent=title;
    document.getElementById('toastMsg').textContent=msg;
    t.style.borderLeftColor = type==='warn' ? 'var(--orange)' : 'var(--green)';
    t.classList.add('show');
    setTimeout(()=>t.classList.remove('show'),3600);
  }

  // add spin keyframe
  const s=document.createElement('style');
  s.textContent='@keyframes spin{to{transform:rotate(360deg)}}';
  document.head.appendChild(s);

  function parseGps(gps) {
    if (!gps || typeof gps !== 'string') return null;
    const m = gps.match(/^\s*(-?\d+(?:\.\d+)?)\s*,\s*(-?\d+(?:\.\d+)?)\s*$/);
    if (!m) return null;
    const lat = Number(m[1]);
    const lng = Number(m[2]);
    if (!Number.isFinite(lat) || !Number.isFinite(lng)) return null;
    if (lat < -90 || lat > 90 || lng < -180 || lng > 180) return null;
    return { lat, lng };
  }

  function toEmbedUrl(lat, lng) {
    return `https://maps.google.com/maps?q=${lat.toFixed(6)},${lng.toFixed(6)}&t=k&z=16&output=embed`;
  }

  function renderReporterMap(gps, label = 'Detected location') {
    const p = parseGps(gps);
    const wrap = document.getElementById('gpsMapWrap');
    if (!p || !wrap) return;
    const src = toEmbedUrl(p.lat, p.lng);
    const openUrl = `https://www.google.com/maps?q=${p.lat.toFixed(6)},${p.lng.toFixed(6)}&t=k`;
    document.getElementById('gpsMapFrame').src = src;
    document.getElementById('gpsMapLink').href = openUrl;
    document.getElementById('gpsMapLabel').textContent = `${label}: ${p.lat.toFixed(5)}, ${p.lng.toFixed(5)}`;
    wrap.style.display = 'block';
  }

  function normText(s) {
    return String(s || '').toLowerCase().replace(/[^a-z0-9]/g, '');
  }

  function pickFirst(parts) {
    for (const p of parts) {
      if (p && String(p).trim()) return String(p).trim();
    }
    return '';
  }

  function maybeSetBarangay(detected) {
    const raw = String(detected || '').trim();
    if (!raw) return false;

    const inp = document.getElementById('iBarangay');
    if (!inp || inp.value.trim()) return false;
    const target = raw.replace(/^brgy\.?\s*/i, 'Barangay ').trim();
    inp.value = target;
    return true;
  }

  function maybeSetLandmark(detected) {
    const text = String(detected || '').trim();
    if (!text) return false;
    const inp = document.getElementById('iLandmark');
    if (inp.value.trim()) return false;
    inp.value = text;
    return true;
  }

  async function reverseGeocode(lat, lng) {
    const url = `/api/reverse-geocode?lat=${encodeURIComponent(lat)}&lng=${encodeURIComponent(lng)}`;
    try {
      const r = await fetch(url);
      if (r.ok) {
        const j = await r.json();
        return {
          barangay: String((j && j.barangay) || '').trim(),
          landmark: String((j && j.landmark) || '').trim(),
          street: String((j && j.street) || '').trim(),
        };
      }
    } catch (_e) {}

    return { barangay: '', landmark: '', street: '' };
  }

  async function buildPanicLocationPayload(gps) {
    const p = parseGps(gps);
    if (!p) {
      return { gps: 'unavailable', barangay: '', landmark: '', street: '', locationText: 'Location unavailable - dispatcher will call you' };
    }

    const info = await reverseGeocode(p.lat, p.lng);
    const barangay = info.barangay || '';
    const street = info.street || '';
    const landmark = info.landmark || `Near ${p.lat.toFixed(5)}, ${p.lng.toFixed(5)}`;
    const locationText = pickFirst([
      [street, landmark, barangay].filter(Boolean).join(', '),
      [landmark, barangay].filter(Boolean).join(', '),
      `GPS ${gps}`,
    ]);

    return {
      gps,
      barangay,
      landmark,
      street,
      locationText: `Location sent: ${locationText}`,
    };
  }

  async function autoFillLocationFromCoords(lat, lng) {
    const info = await reverseGeocode(lat, lng);
    const fallbackLandmark = `Near ${lat.toFixed(5)}, ${lng.toFixed(5)}`;
    const changedBarangay = maybeSetBarangay(info.barangay || '');
    const changedLandmark = maybeSetLandmark(info.landmark ? `Near ${info.landmark}` : fallbackLandmark);
    if (changedBarangay || changedLandmark) {
      toast('Location autofill', 'Barangay/Landmark populated from detected GPS.');
    }
  }

  async function tryGetLiveGps(timeoutMs = 12000) {
    if (!navigator.geolocation) return null;
    return new Promise(resolve => {
      navigator.geolocation.getCurrentPosition(
        pos => {
          const gps = `${pos.coords.latitude.toFixed(5)}, ${pos.coords.longitude.toFixed(5)}`;
          document.getElementById('iGPS').value = gps;
          document.getElementById('iGPSAt').value = String(Date.now());
          document.getElementById('iGPSAcc').value = String(Math.round(pos.coords.accuracy || 0));
          renderReporterMap(gps, 'Detected location');
          void autoFillLocationFromCoords(pos.coords.latitude, pos.coords.longitude);
          resolve(gps);
        },
        () => resolve(null),
        { enableHighAccuracy: true, timeout: timeoutMs, maximumAge: 0 }
      );
    });
  }
</script>
</body>
</html>

